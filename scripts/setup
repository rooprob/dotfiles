#!/bin/bash
set -euo pipefail

if [ -z "${PRIVATE_BIN:-}" ]; then
    echo "error: need to export PRIVATE_BIN"
    exit 1
fi

mkdir -p "$PRIVATE_BIN"

if command -v cargo >/dev/null 2>&1; then
    cargo install --locked ccase
else
    echo "warning: cargo not found, skipping ccase install"
fi

rsync -avx --exclude setup . "$PRIVATE_BIN"/
