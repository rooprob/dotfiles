#!/bin/bash
set -euo pipefail

[ -d frame ] || git clone https://github.com/lelanthran/frame
[ -d frame ] && {
    pushd frame >/dev/null || exit
    git pull --ff-only
    popd >/dev/null || exit
}

pushd frame >/dev/null || exit

if [ ! -d /opt/frame ]; then
    echo "Needing sudo password please ..."
    sudo mkdir -p /opt/frame
    sudo chown "$USER" /opt/frame
fi

make release INSTALL_PREFIX=/opt/frame TARGET=""

mkdir -p "$HOME/.bin"
if compgen -G "/opt/frame/bin/frame.*" >/dev/null; then
    ln -sfn "$(ls /opt/frame/bin/frame.* | head -n 1)" "$HOME/.bin/frame"
elif [ -e /opt/frame/bin/frame ]; then
    ln -sfn /opt/frame/bin/frame "$HOME/.bin/frame"
else
    echo "warning: no frame binary found in /opt/frame/bin"
fi

popd >/dev/null || exit
